    {
      "parameters": {
        "jsCode": "const fs = $('Feature Selection').item.json;\nconst formData = $input.first().json;\n\nconst daEscludere = (formData['Sensore da escludere'] || '').trim().toUpperCase();\n\n// Rimuove il sensore da df_tall\nconst dfTall = { ...fs.df_tall };\nif (daEscludere) delete dfTall[daEscludere];\n\n// num_clusters ridotto di 1 perché un gruppo termico sparisce\nconst numClusters = Math.max(2, fs.cluster_map ? Object.keys(fs.cluster_map).length - 1 : 5);\n\nreturn [{\n  json: {\n    df_tall:      dfTall,\n    df_dis:       fs.df_dis,\n    num_clusters: numClusters,\n    sensore_escluso: daEscludere\n  }\n}];\n"
