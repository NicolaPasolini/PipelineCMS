    {
      "parameters": {
        "jsCode": "const curr = $input.first().json;\n\n// Se sensor removal ha settato questo flag, siamo nel branch B\nconst isModified = !!curr['sensore_escluso'];\n\nconst fs = isModified\n  ? $('code fs2').item.json        // ← Feature Selection ri-eseguita senza il sensore\n  : $('Feature Selection').item.json;  // ← Feature Selection originale\n\nreturn [{\n  json: {\n    df_clustered: fs.df_clustered,\n    df_tall:      fs.df_tall,\n    df_dis:       fs.df_dis,\n    displ:        3,\n    k_folds:      10,\n    random_state: 42\n  }\n}];\n"
      },
