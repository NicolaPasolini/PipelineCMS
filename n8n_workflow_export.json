    {
      "parameters": {
        "jsCode": "const prep = $('Preprocessing').first().json;\nconst fs = $('Feature Selection').first().json;\nconst train = $('Training').first().json;\nconst evaln = $('Evaluation').first().json;\nconst refNode = $('Reference Notebook').first().json;\n\nlet ref;\n\nif (refNode.reference && typeof refNode.reference === 'object') {\n  ref = refNode.reference;\n} else if (refNode.reference && typeof refNode.reference === 'string') {\n  ref = JSON.parse(refNode.reference);\n} else {\n  ref = refNode;\n}\n\nfunction diff(a, b) {\n  if (a === undefined || b === undefined || a === null || b === null) return null;\n  return Math.abs(Number(a) - Number(b));\n}\n\nfunction approxEqual(a, b, tol = 1e-6) {\n  const d = diff(a, b);\n  return d !== null && d <= tol;\n}\n\nfunction sameArray(a, b) {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\nfunction arrayApproxEqual(a, b, tol = 1e-6) {\n  if (!Array.isArray(a) || !Array.isArray(b) || a.length !== b.length) return false;\n  for (let i = 0; i < a.length; i++) {\n    if (Math.abs(Number(a[i]) - Number(b[i])) > tol) return false;\n  }\n  return true;\n}\n\nconst checks = {\n  preprocessing_rows: prep.info.rows === ref.preprocessing.rows,\n  preprocessing_cols_tall: prep.info.cols_tall === ref.preprocessing.cols_tall,\n  preprocessing_cols_dis: prep.info.cols_dis === ref.preprocessing.cols_dis,\n  preprocessing_T1_first: approxEqual(prep.info.T1_first, ref.preprocessing.T1_first, 1e-6),\n  preprocessing_D3_first: approxEqual(prep.info.D3_first, ref.preprocessing.D3_first, 1e-6),\n  preprocessing_D3_min: approxEqual(prep.info.D3_min, ref.preprocessing.D3_min, 1e-4),\n  preprocessing_D3_max: approxEqual(prep.info.D3_max, ref.preprocessing.D3_max, 1e-4),\n  preprocessing_columns_tall: sameArray(prep.info.columns_tall, ref.preprocessing.columns_tall),\n  preprocessing_columns_dis: sameArray(prep.info.columns_dis, ref.preprocessing.columns_dis),\n\n  feature_selection_selected: sameArray(fs.selected_features, ref.feature_selection.selected_features),\n\n  training_target_col: train.target.col_name === ref.training.target_col,\n  training_target_index: train.target.col_index === ref.training.target_index,\n\n  mlra_intercept: approxEqual(train.mlra.avg_intercept, ref.training.mlra.avg_intercept, 1e-6),\n  mlra_rmse: approxEqual(train.mlra.rmse, ref.training.mlra.rmse, 1e-6),\n  mlra_pearson: approxEqual(train.mlra.pearson_r, ref.training.mlra.pearson_r, 1e-6),\n  mlra_coef: arrayApproxEqual(train.mlra.avg_coef, ref.training.mlra.avg_coef, 1e-6),\n  mlra_features: sameArray(train.mlra.features, ref.training.mlra.features),\n\n  lasso_alpha: approxEqual(train.lasso.best_alpha, ref.training.lasso.best_alpha, 1e-6),\n  lasso_intercept: approxEqual(train.lasso.avg_intercept, ref.training.lasso.avg_intercept, 1e-6),\n  lasso_rmse: approxEqual(train.lasso.rmse, ref.training.lasso.rmse, 1e-6),\n  lasso_pearson: approxEqual(train.lasso.pearson_r, ref.training.lasso.pearson_r, 1e-6),\n  lasso_coef: arrayApproxEqual(train.lasso.avg_coef, ref.training.lasso.avg_coef, 1e-6),\n  lasso_features: sameArray(train.lasso.features, ref.training.lasso.features),\n\n  evaluation_model: evaln.suggested_model === ref.evaluation.suggested_model,\n};\n\nconst failed_checks = Object.entries(checks)\n  .filter(([_, passed]) => !passed)\n  .map(([name]) => name);\n\nreturn [{\n  json: {\n    esito: failed_checks.length === 0 ? 'VALIDO' : 'NON VALIDO',\n    failed_checks\n  }\n}];\n"
      },
