      "id": "1985953c-c4b5-4248-9d14-5a62cdc9bf0e",
      "name": "Body5"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst features = input.selected_features;\nconst clusterMap = input.cluster_map;\n\nconst featureListText = features.join(\", \");\n\n// Solo per uso interno/debug — non va nel form\nconst clusterSummary = Object.values(clusterMap)\n  .map(c => {\n    const count = c.members.length;\n    const label = count === 1 ? \"sensore\" : \"sensori\";\n    return `${c.representative} (rappresenta ${count} ${label}: ${c.members.join(\", \")})`;\n  })\n  .join(\"\\n\");\n\n// Testo che vede l'operatore — semplice e diretto\nconst formDescription =\n  `Il sistema userà questi ${features.length} sensori per il modello:\\n\\n` +\n  `📍 ${featureListText}\\n\\n` +\n  `Se sai che uno di questi è guasto o fuori servizio, indicalo qui sotto.\\n` +\n  `Altrimenti, seleziona \"Nessun problema\" per procedere.`;\n\nreturn [{\n  json: {\n    df_clustered:     input.df_clustered,\n    df_dis:           input.df_dis,\n    df_tall:          input.df_tall,\n    selected_features: input.selected_features,\n    cluster_map:      input.cluster_map,\n    hitl1: {\n      featureListText,\n      clusterSummary,   // disponibile per debug, non mostrato nel form\n      formDescription,\n      numFeatures: features.length\n    }\n  }\n}];\n"
      },
